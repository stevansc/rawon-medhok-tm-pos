{
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/vite"
    }
  ],
  "routes": [
    { "src": "/orders(.*)", "dest": "/backend/main.py" },
    { "src": "/menu(.*)", "dest": "/backend/main.py" },
    { "src": "/branches(.*)", "dest": "/backend/main.py" },
    { "src": "/dashboard(.*)", "dest": "/backend/main.py" },
    { "src": "/admin(.*)", "dest": "/backend/main.py" },
    { "src": "/categories(.*)", "dest": "/backend/main.py" },
    { "src": "/token(.*)", "dest": "/backend/main.py" },
    { "src": "/docs(.*)", "dest": "/backend/main.py" },
    { "src": "/openapi.json(.*)", "dest": "/backend/main.py" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
